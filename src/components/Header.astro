---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const categories = [
	{ name: '🍫 お菓子メーカー', slug: 'お菓子メーカー' },
	{ name: '🏪 お菓子屋さん巡り', slug: 'お菓子屋さん巡り' },
	{ name: '🌱 市民農園', slug: '市民農園' },
	{ name: '🚗 全道出張', slug: '全道出張' },
	{ name: '💬 おまけ話', slug: 'おまけ話' },
];
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">ブログ</HeaderLink>
			<div class="dropdown">
				<span class="dropdown-label">カテゴリー ▾</span>
				<div class="dropdown-menu">
					{categories.map(cat => (
						<a href={`/blog/category/${cat.slug}`}>{cat.name}</a>
					))}
				</div>
			</div>
			<HeaderLink href="/about">このブログについて</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.instagram.com/suzuki.com_179/" target="_blank">
				<span class="sr-only">Instagramをフォロー</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: #fde8e8;
		box-shadow: 0 2px 12px rgba(244, 167, 185, 0.2);
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
		font-family: 'Hiragino Maru Gothic ProN', 'Hiragino Sans', sans-serif;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #5c3d2e;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	nav a {
		padding: 1em 0.75em;
		color: #8b6355;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #f4a7b9;
		color: #5c3d2e;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.dropdown {
		position: relative;
		display: flex;
		align-items: center;
	}
	.dropdown-label {
		padding: 1em 0.75em;
		color: #8b6355;
		font-size: 0.95em;
		cursor: pointer;
		white-space: nowrap;
		user-select: none;
	}
	.dropdown-menu {
		display: none;
		position: absolute;
		top: calc(100% + 4px);
		left: 50%;
		transform: translateX(-50%);
		background: white;
		border-radius: 0.75rem;
		box-shadow: 0 4px 16px rgba(244, 167, 185, 0.3);
		min-width: 190px;
		z-index: 100;
		padding: 0.5rem 0;
		border: 1px solid #fde8e8;
	}
	.dropdown-menu a {
		display: block;
		padding: 0.6em 1.2em;
		color: #5c3d2e;
		border-bottom: none !important;
		font-size: 0.9em;
		text-decoration: none;
	}
	.dropdown-menu a:hover {
		background: #fff8f0;
		color: #c97b84;
	}
	.dropdown:hover .dropdown-menu {
		display: block;
	}
	.social-links,
	.social-links a {
		display: flex;
		color: #c97b84;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
